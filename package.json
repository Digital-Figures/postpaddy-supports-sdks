{
  "name": "postpaddy-supports-sdks",
  "private": true,
  "workspaces": [
    "packages/supports-react-native"
  ],
  "scripts": {
    "build": "npm run build:react-native",
    "build:react-native": "npm --workspace @postpaddy/supports-react-native run typecheck",
    "publish:react-native": "npm --workspace @postpaddy/supports-react-native publish --access public",
    "check:react-native-pack": "npm --workspace @postpaddy/supports-react-native pack --dry-run"
  }
}
