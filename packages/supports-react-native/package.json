{
  "name": "@postpaddy/supports-react-native",
  "version": "0.1.1",
  "description": "React Native SDK for Postpaddy Supports — chat, attachments, realtime. Drop-in: just your widget id.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "files": [
    "dist",
    "src",
    "ios",
    "android",
    "*.podspec",
    "react-native.config.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": ["postpaddy", "supports", "chat", "support", "react-native"],
  "license": "MIT",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71",
    "@supabase/supabase-js": ">=2.45.0",
    "expo-image-picker": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": { "optional": true },
    "expo-image-picker": { "optional": true }
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/react": "^19.2.2",
    "expo-image-picker": "^14.7.1",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
